# Base URL of the Calldeals Dashboard (.NET) API — serves JSON. Used server-side only.
# Dev default matches the API's http launch profile.
API_BASE_URL=http://localhost:5050

# Host that serves CMS-uploaded media (/uploads/...). In this stack uploads are
# stored in and served by the Admin app, which runs on a DIFFERENT port than the
# API — so this is set separately. In production, point it at wherever media is
# hosted (Admin host / CDN / shared storage).
MEDIA_BASE_URL=http://localhost:5209
